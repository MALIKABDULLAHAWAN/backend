# API Configuration
# Note: Backend uses /api/v1/ prefix for all endpoints
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Groq AI API Configuration (Optional - backend handles AI)
# Get your API key from: https://console.groq.com/keys
# Only needed if using direct frontend AI calls
VITE_GROQ_API_KEY=gsk_your_api_key_here
VITE_GROQ_MODEL=llama3-8b-8192
VITE_GROQ_TEMPERATURE=0.7
VITE_GROQ_MAX_TOKENS=1024

# Voice Agent Configuration
VITE_VOICE_AGENT_URL=http://localhost:5000
VITE_VOICE_ENABLED=true

# Feature Flags
VITE_AI_CACHE_ENABLED=true
VITE_VOICE_RECOGNITION_ENABLED=true
