# Django Settings
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dhyan
DB_USER=dhyan
DB_PASSWORD=dhyan
DB_SSLMODE=prefer

# JWT Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH=0
JWT_BLACKLIST_AFTER_ROTATION=1

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=0

# API Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI Service Configuration
AI_MODEL_DEFAULT=llama-3.3-70b-versatile
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_CACHE_ENABLED=1
AI_CACHE_TTL=3600

# Voice Agent Configuration
VOICE_AGENT_ENABLED=1
VOICE_AGENT_PORT=5000
VOICE_AGENT_HOST=0.0.0.0
VOICE_AGENT_SSL=1
VOICE_MUSIC_CACHE_ENABLED=1

# Audio Processing
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
SPEAKER_VERIFICATION_THRESHOLD=0.30

# Email
DEFAULT_FROM_EMAIL=noreply@dhyan.com

# External Services (optional)
# ASR_HTTP_URL=http://localhost:8001/transcribe
# TTS_HTTP_URL=http://localhost:8002/synthesize
